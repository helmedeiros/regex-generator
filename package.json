  },
  "devDependencies": {
    "@types/jest": "22.2.3",
    "jest": "22.4.4",
    "prettier": "1.10.2",
    "ts-jest": "22.4.6",
    "tslint": "5.9.1",
    "tslint-config-prettier": "1.10.0",
    "typescript": "2.7.2"
  }
}
