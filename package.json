{
  "name": "regex-generator",
  "version": "0.1.0",
  "description": "A web tool that turns sample text into a regular expression.",
  "license": "MIT",
  "author": "helmedeiros",
  "private": true,
  "scripts": {
    "lint": "tslint -p tsconfig.json",
    "format:check": "prettier --list-different \"src/**/*.{ts,tsx}\"",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "test": "jest"
  },
  "dependencies": {
    "react": "16.2.0",
    "react-dom": "16.2.0"
  },
  "devDependencies": {
    "@types/enzyme": "3.1.10",
    "@types/enzyme-adapter-react-16": "1.0.2",
    "@types/jest": "22.2.3",
    "@types/node": "9.4.7",
    "@types/react": "16.0.40",
    "@types/react-dom": "16.0.4",
    "cheerio": "1.0.0-rc.2",
    "enzyme": "3.3.0",
    "enzyme-adapter-react-16": "1.1.1",
    "jest": "22.4.4",
    "react-test-renderer": "16.2.0",
    "prettier": "1.10.2",
    "ts-jest": "22.4.6",
    "tslint": "5.9.1",
    "tslint-config-prettier": "1.10.0",
    "typescript": "2.7.2"
  }
}
